{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build --workspace backend && npm run build --workspace frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

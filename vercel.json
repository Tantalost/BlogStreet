{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build --workspace backend && npm run build --workspace frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/dist/api/[...path].js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
